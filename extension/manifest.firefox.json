{
  "manifest_version": 3,
  "name": "Desouper",
  "version": "0.1.0",
  "description": "Detects and filters alphabet soup sellers with gibberish names from Amazon and Walmart search results.",
  "browser_specific_settings": {
    "gecko": {
      "id": "desouper@desouper.dev",
      "strict_min_version": "109.0"
    }
  },
  "permissions": [
    "storage",
    "activeTab"
  ],
  "host_permissions": [
    "*://*.amazon.com/*",
    "*://*.walmart.com/*"
  ],
  "background": {
    "scripts": ["src/background.js"]
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.amazon.com/s*",
        "*://*.amazon.com/s?*"
      ],
      "js": [
        "src/scorer.js",
        "src/enricher.js",
        "src/selectors.js",
        "src/content.js"
      ],
      "css": [
        "src/content.css"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "*://*.walmart.com/search*"
      ],
      "js": [
        "src/scorer.js",
        "src/enricher.js",
        "src/selectors.js",
        "src/content.js"
      ],
      "css": [
        "src/content.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
